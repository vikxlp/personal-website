{{- "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:media="http://search.yahoo.com/mrss/">
  <channel>
    <title>Postcards from Vikalp</title>
    <link>{{ .Permalink }}</link>
    <description>{{ .Site.Params.description }}</description>
    <language>{{ .Site.LanguageCode }}</language>
    <atom:link href="{{ .Permalink }}index.xml" rel="self" type="application/rss+xml" />
    <image>
      <url>{{ "/images/profile.png" | absURL }}</url>
      <title>{{ .Site.Title }}</title>
      <link>{{ .Permalink }}</link>
      <width>144</width>
      <height>144</height>
    </image>
    {{- range .Pages }}
    {{- $page := . }}
    <item>
      <title>{{ .Date.Format "2 Jan 2006" }}</title>
      <link>{{ .Permalink }}</link>
      <pubDate>{{ .Date.Format "Mon, 02 Jan 2006 15:04:05 -0700" }}</pubDate>
      <guid>{{ .Permalink }}</guid>
      {{ with $page.Params.cover -}}
      <description>{{ printf "<![CDATA[<figure><img src=\"%s\" alt=\"%s\"></figure>%s]]>" (. | absURL) ($page.Params.coverAlt | default "") $page.Content | safeHTML }}</description>
      <media:thumbnail url="{{ . | absURL }}" />
      <media:content url="{{ . | absURL }}" medium="image" />
      {{- else -}}
      <description>{{ printf "<![CDATA[%s]]>" $page.Content | safeHTML }}</description>
      {{- end }}
    </item>
    {{- end }}
  </channel>
</rss>
